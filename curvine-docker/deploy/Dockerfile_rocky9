# ============================================================
# EPEL + CRB (runtime base)
# ============================================================
FROM rockylinux:9 AS epel-base

RUN --mount=type=cache,sharing=locked,target=/var/cache/dnf \
    dnf install -y epel-release && \
    dnf config-manager --set-enabled crb && \
    dnf clean all

# ============================================================
# Common runtime packages (shared by spdk-full and runtime)
# ============================================================
FROM epel-base AS runtime-base

RUN --mount=type=cache,sharing=locked,target=/var/cache/dnf \
    dnf install -y \
    libaio numactl-libs libuuid openssl-libs \
    python3 procps-ng \
    rdma-core libibverbs librdmacm \
    && dnf clean all

# ============================================================
# SPDK artifacts come from the compile image
# ============================================================
FROM ghcr.io/curvineio/curvine-compile:rocky9 AS spdk-artifacts

# ============================================================
# Full runtime for NVMe-oF Target nodes
# ============================================================
FROM runtime-base AS spdk-full

RUN --mount=type=cache,sharing=locked,target=/var/cache/dnf \
    dnf install -y \
    ncurses-libs kmod pciutils libffi fuse3-libs \
    && dnf clean all

COPY --from=spdk-artifacts /opt/spdk /opt/spdk

RUN ldconfig && \
    mkdir -p /var/log/spdk /var/run/spdk

ENV SPDK_DIR=/opt/spdk
ENV LD_LIBRARY_PATH="/opt/spdk/build/lib:/opt/spdk/dpdk/build/lib:/opt/spdk/isa-l/.libs:/opt/spdk/isa-l-crypto/.libs"
EXPOSE 4420

# ============================================================
# Stage 3: Target runtime (SPDK NVMe-oF target)
# ============================================================
FROM spdk-full AS target-runtime

LABEL stage="target-runtime"

COPY curvine-docker/deploy/spdk/entrypoint-target.sh /entrypoint-target.sh
RUN chmod +x /entrypoint-target.sh

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
    CMD /opt/spdk/scripts/rpc.py -s /var/tmp/spdk.sock rpc_get_methods >/dev/null 2>&1 || exit 1

ENTRYPOINT ["/entrypoint-target.sh"]

# ============================================================
# Build stage - Use pre-built compile image with all toolchains
# ============================================================
FROM ghcr.io/curvineio/curvine-compile:rocky9 AS builder

# Add metadata labels
ARG REPO_URL=https://github.com/curvineio/curvine
LABEL org.opencontainers.image.source="${REPO_URL}"
LABEL org.opencontainers.image.description="Curvine Native Kubernetes Runtime Image"

# Override ENTRYPOINT to ensure RUN commands execute correctly
# The compile image has ENTRYPOINT ["/bin/bash", "-c"] which can interfere with RUN
ENTRYPOINT []

# Build-time package/UFS/feature selection (override with --build-arg BUILD_ARGS="...")
# Examples:
#   -p core --ufs opendal-s3 --spdk-rdma                   # Core + S3 + SPDK-RDMA
#   -p server -p client -p tests --ufs opendal-s3 --spdk   # Bench + SPDK-TCP only
ARG BUILD_ARGS="-p server -p client -p cli -p fuse -p web --skip-java-sdk --skip-python-sdk --ufs opendal-s3 --ufs opendal-oss --ufs opendal-azblob --ufs opendal-gcs --ufs opendal-hdfs-native --ufs oss-hdfs --spdk-rdma"

# Copy and apply build configurations
COPY curvine-docker/deploy/config /build-config/config
RUN mkdir -p /root/.cargo && \
    cp /build-config/config /root/.cargo/config.toml

# Ensure environment variables are set (from compile image)
ENV PATH="/root/.cargo/bin:/app/protoc/bin:/app/maven/bin:${PATH}"

# Copy and build source code if building from source
COPY . /workspace/
WORKDIR /workspace

# SPDK build artifacts are provided by the compile image.
ENV SPDK_DIR=/opt/spdk
ENV PKG_CONFIG_PATH=/usr/local/lib64/pkgconfig:/usr/local/lib/pkgconfig

# 6. Build the runtime project from source.
RUN echo "Building Curvine from source..." && \
    export CURVINE_HOME=/workspace && \
    # Use workspace tmp directory instead of /tmp to avoid "no space left on device"
    mkdir -p /workspace/tmp && \
    export TMPDIR=/workspace/tmp && \
    echo "Using TMPDIR=$TMPDIR for compilation temporary files" && \
    echo "Running runtime build with retry mechanism: make all ARGS=\"${BUILD_ARGS}\"" && \
    # Build with retry mechanism
    for attempt in 1 2 3; do \
        echo "Build attempt $attempt..." && \
        if make all ARGS="${BUILD_ARGS}"; then \
            echo "✓ Build succeeded with 'make all ${BUILD_ARGS}'" && \
            break; \
        else \
            echo "✗ Build attempt $attempt failed" && \
            if [ $attempt -eq 3 ]; then \
                echo "✗ All build attempts failed" && \
                exit 1; \
            fi && \
            echo "Retrying... (attempt $((attempt + 1))/3)" && \
            sleep 10; \
        fi; \
    done && \
    if [ ! -d "/workspace/build/dist" ]; then \
        echo "✗ ERROR: /workspace/build/dist not found after build" && \
        exit 1; \
    fi && \
    # Clean up temporary files to reduce image size
    rm -rf /workspace/tmp

# 9. Create output directory and copy build artifacts from build/dist
RUN mkdir -p /build-output && \
    echo "Copying build/dist contents to /build-output..." && \
    cp -r /workspace/build/dist/* /build-output/ && \
    # Verify critical files exist
    if [ ! -f "/build-output/bin/launch-process.sh" ]; then \
        echo "✗ ERROR: launch-process.sh not found in build/dist/bin" && \
        exit 1; \
    fi && \
    if [ ! -f "/build-output/lib/curvine-server" ]; then \
        echo "✗ ERROR: curvine-server not found in build/dist/lib" && \
        exit 1; \
    fi && \
    echo "Build output summary:" && \
    echo "  bin/: $(ls -1 /build-output/bin 2>/dev/null | wc -l) files" && \
    echo "  lib/: $(ls -1 /build-output/lib 2>/dev/null | wc -l) files" && \
    echo "  conf/: $(ls -1 /build-output/conf 2>/dev/null | wc -l) files"

# Runtime stage
FROM runtime-base AS runtime

RUN --mount=type=cache,sharing=locked,target=/var/cache/dnf \
    dnf install -y --allowerasing \
    fuse3 zlib libstdc++ nvme-cli \
    && dnf clean all && rm -rf /var/cache/dnf/*

# Copy ISA-L shared libs for SPDK initiator (built into the compile image)
COPY --from=builder /opt/spdk/isa-l/.libs/libisal* /usr/lib64/
COPY --from=builder /opt/spdk/isa-l-crypto/.libs/libisal* /usr/lib64/
RUN ldconfig

# Copy JindoSDK from builder stage for OSS-HDFS support
COPY --from=builder /opt/jindosdk /opt/jindosdk

ENV JINDOSDK_HOME=/opt/jindosdk
ENV LD_LIBRARY_PATH="${JINDOSDK_HOME}/lib/native:${JINDOSDK_HOME}/lib"

# Create curvine directories
RUN mkdir -p /app/curvine \
    && mkdir -p /opt/curvine/data/{meta,journal} \
    && mkdir -p /opt/curvine/logs

# Always create the base directory structure
RUN mkdir -p /app/curvine/bin /app/curvine/lib /app/curvine/conf

# Copy from builder stage when building from source
COPY --from=builder /build-output/ /app/curvine/

# Copy entrypoint script
COPY curvine-docker/deploy/entrypoint.sh /entrypoint.sh
COPY curvine-docker/fluid/entrypoint.sh /fluid-entrypoint.sh
COPY curvine-docker/fluid/generate_config.py /app/curvine/generate_config.py
COPY curvine-docker/fluid/config-parse.py /app/curvine/config-parse.py
COPY curvine-docker/fluid/mountUfs.sh /app/curvine/mountUfs.sh

# Make all binaries and scripts executable
RUN find /app/curvine -type f -name "*.sh" -exec chmod +x {} \; \
    && find /app/curvine -type f -path "*/bin/*" -exec chmod +x {} \; \
    && find /app/curvine -type f -path "*/lib/*" -exec chmod +x {} \; \
    && chmod +x /app/curvine/generate_config.py /app/curvine/config-parse.py /app/curvine/mountUfs.sh \
    && chmod +x /fluid-entrypoint.sh \
    && chmod +x /entrypoint.sh

# Set environment variables
ENV APP_HOME=/app
ENV CURVINE_HOME=/app/curvine
ENV PATH=$PATH:$CURVINE_HOME/bin

# Override environment settings for container
ENV ORPC_BIND_HOSTNAME=0.0.0.0
ENV CURVINE_CONF_FILE=$CURVINE_HOME/conf/curvine-cluster.toml

WORKDIR $APP_HOME

# Expose ports
# 8995: Master RPC
# 8996: Master Journal/Raft
# 8997: Worker RPC
# 9000: Master Web UI
# 9001: Worker Web UI / Master Web1
EXPOSE 8995 8996 8997 9000 9001

ENTRYPOINT ["/entrypoint.sh"]
CMD ["master", "start"]
